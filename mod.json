{
	"geode": "5.1.0",
	"gd": {
		"win": "2.2081"

	},
	"id": "olimbo.multitask",
	"name": "Multitask",
	"version": "v0.0.1",
	"developers": [
		"Chillsy",
		"Misha_Opstal"
	],
	"description": "Multitask is a way to allow playing geometry dash in the background.",
	"links": {
		"source": "https://github.com/OlimboDev/Multitask"
	},
	"issues": {
		"info": "If you find any bugs or have suggestions we prefer you to report them on our GitHub issue tracker. if you don't have a GitHub account you can also report them to Chillsy. (includes the dot) or Misha_Opstal on Discord.",
		"url": "https://github.com/OlimboDev/Multitask/issues"
	},
	"tags": [
		"offline",
		"enhancement",
		"utility"
	],
	"settings": {
		"enabled": {
			"type": "bool",
			"name": "Enabled",
			"default": true,
			"description": "Enable or disable the mod"
		},
		"firstPlayerUpKey": {
			"type": "keybind",
			"name": "Up key for player 1",
			"default": "Up",
			"description": "Up"
		},
		"firstPlayerLeftKey": {
			"type": "keybind",
			"name": "Left key for player 1",
			"default": "Left",
			"description": "Left"
		},
		"firstPlayerRightKey": {
			"type": "keybind",
			"name": "Right key for player 1",
			"default": "Right",
			"description": "Right"
		},
		"secondPlayerUpKey": {
			"type": "keybind",
			"name": "Up key for player 2",
			"default": "W",
			"description": "Up"
		},
		"secondPlayerLeftKey": {
			"type": "keybind",
			"name": "Left key for player 2",
			"default": "A",
			"description": "Left"
		},
		"secondPlayerRightKey": {
			"type": "keybind",
			"name": "Right key for player 2",
			"default": "D",
			"description": "Right"
		},
		"pauseGameKey": {
			"type": "keybind",
			"name": "Pause game key",
			"default": "Escape",
			"description": "Pause game"
		}
	},
	"dependencies": {
		"geode.node-ids": {
			"version": ">=v1.20.0",
			"importance": "required"
		}
	}
}
